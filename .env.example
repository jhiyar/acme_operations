# Copy to backend/.env (and optionally root .env for compose substitution).
# Local demo defaults — do not use these secrets outside a local/dev box.

DJANGO_SECRET_KEY=django-insecure-local-dev-only-change-me
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Postgres (host defaults to localhost; compose overrides POSTGRES_HOST)
POSTGRES_DB=acme
POSTGRES_USER=acme
POSTGRES_PASSWORD=acme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Keycloak
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_ISSUER_URL=http://localhost:8080
KEYCLOAK_REALM=acme
KEYCLOAK_CLIENT_ID=acme-frontend
KEYCLOAK_AUDIENCE=acme-frontend
# User management UI (Admin REST via master admin-cli — local demo only)
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# LLM / agent
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
AGENT_MAX_TOOL_ROUNDS=12
AGENT_HISTORY_MAX_TURNS=8
AGENT_HISTORY_MAX_CHARS_PER_TURN=1200

# Redis memory / cache
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL_SECONDS=3600
REDIS_SESSION_MAX_TURNS=40
REDIS_CACHE_TTL_SECONDS=300
REDIS_TOOL_TTL_SECONDS=120
REDIS_TRACE_TTL_SECONDS=86400

# Observability file traces under backend/evals/traces/
OBSERVABILITY_WRITE_FILES=true
LOG_LEVEL=INFO

# LangSmith (optional — LangGraph agent traces)
# LANGCHAIN_TRACING_V2=true
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=acme-operations
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
